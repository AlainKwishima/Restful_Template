NODE_ENV=development
PORT=4000
HOST=0.0.0.0
API_PREFIX=/api/v1
APP_NAME=National_Examination
APP_URL=http://localhost:4000

DATABASE_URL=postgresql://root:mukabareke@localhost:5432/national_examination?schema=public&connection_limit=5&pool_timeout=5

JWT_ACCESS_SECRET=replace-with-a-strong-32-byte-secret
JWT_REFRESH_SECRET=replace-with-a-strong-32-byte-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_ISSUER=enterprise-backend
JWT_AUDIENCE=enterprise-backend-clients

ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=1

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=info
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=10

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com
